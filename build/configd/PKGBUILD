pkgname="carbonio-configd"
pkgver="1.0.0"
pkgrel="1"
pkgdesc="High-performance configuration daemon for Carbonio with service management and legacy wrappers"
arch=('x86_64')
maintainer="Zextras <packages@zextras.com>"
copyright=('2026, Zextras <https://www.zextras.com>')
license=("AGPL-3.0-only")
url="https://github.com/zextras"
section="mail"
priority="optional"
options=('!strip')
makedepends=(
  'upx'
)
makedepends__apt=(
  'upx-ucl'
)
depends__apt=(
  "libsystemd0"
  "polkitd"
)
depends__ubuntu_noble=(
  "libsystemd0"
  "polkitd"
)
depends__yum=(
  "systemd-libs"
  "polkit"
)
depends__rocky_9=(
  "systemd-libs"
  "polkit"
)
source=(
  "${pkgname}-completion.bash"
  "${pkgname}-legacy.service"
  "${pkgname}-wrappers-completion.bash"
  "${pkgname}.rules"
  "${pkgname}.service"
)
sha256sums=(
  'a16bbcc3f76bacb1d1d630c2163055b444f8154c3e2b98100c395758cf9cc6bb'
  'd247f79bbbe9cc5b7c09aed0632780f8361c7cf69944cc8574408755b99936a9'
  '57fd0c840d4fcc30e900d44119b0b1d2e763ec14da0818f25661ee4464a0e521'
  '2852da97671727f9ddd10d07289f25976d4032364bae8912687186bc4ae3d4ad'
  '2284bc09bf2ae83d41f3217dff6687d2834bb9653ad55b1f1c673546ccf8b566'
