_package_common() {
  install -Dm755 "${srcdir}/configd" \
    "${pkgdir}/opt/zextras/bin/configd"

  # Polkit policy — allow zextras to manage carbonio systemd units
  install -Dm644 "${srcdir}/${pkgname}.rules" \
    "${pkgdir}/usr/share/polkit-1/rules.d/50-carbonio-configd.rules"

  # Bash completion (system-wide and zextras user)
  install -Dm644 "${srcdir}/${pkgname}-completion.bash" \
    "${pkgdir}/usr/share/bash-completion/completions/configd"
  install -Dm644 "${srcdir}/${pkgname}-completion.bash" \
    "${pkgdir}/opt/zextras/common/share/bash-completion/completions/configd"

  # Bash completion for compatibility wrappers
  install -Dm644 "${srcdir}/${pkgname}-wrappers-completion.bash" \
    "${pkgdir}/usr/share/bash-completion/completions/configd-wrappers"
  install -Dm644 "${srcdir}/${pkgname}-wrappers-completion.bash" \
    "${pkgdir}/opt/zextras/common/share/bash-completion/completions/configd-wrappers"
}

_package_legacy() {
  install -Dm644 "${srcdir}/${pkgname}-legacy.service" \
    "${pkgdir}/lib/systemd/system/carbonio-configd.service"
}

_package_systemd() {
  install -Dm644 "${srcdir}/${pkgname}.service" \
    "${pkgdir}/lib/systemd/system/carbonio-configd.service"
}

build() {
  cd "$(dirname "$(find /project -name "yap.json" -print -quit)")/.."
  CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" \
    -o "${srcdir}/configd" ./cmd/configd/

  # Compress with UPX to reduce binary size by ~70%
  upx "${srcdir}/configd"
}

package() {
  _package_common
  _package_systemd
}

package__rocky_8() {
  _package_common
  _package_legacy
}

package__rocky_9() {
  _package_common
  _package_systemd
}

package__ubuntu_jammy() {
  _package_common
  _package_legacy
}

package__ubuntu_noble() {
  _package_common
  _package_systemd
}

postinst__apt() {
  if [ -d /run/systemd/system ]; then
    systemctl daemon-reload &>/dev/null || :
    if [ "$1" = "configure" ] && [ -z "$2" ]; then
      systemctl enable carbonio-configd.service &>/dev/null || :
    fi
  fi
}

postinst__yum() {
  if [ -d /run/systemd/system ]; then
    systemctl daemon-reload &>/dev/null || :
    if [ $1 -eq 1 ]; then
      systemctl enable carbonio-configd.service &>/dev/null || :
    fi
  fi
}

prerm__apt() {
  if [ -d /run/systemd/system ]; then
    case "$1" in
      remove)
        systemctl --no-reload disable --now carbonio-configd.service &>/dev/null || :
        ;;
      upgrade)
        systemctl --no-reload stop carbonio-configd.service &>/dev/null || :
        ;;
    esac
  fi
}

prerm__yum() {
  if [ -d /run/systemd/system ]; then
    if [ $1 -eq 0 ]; then
      systemctl --no-reload disable --now carbonio-configd.service &>/dev/null || :
    else
      systemctl --no-reload stop carbonio-configd.service &>/dev/null || :
    fi
  fi
}

postrm() {
  if [ -d /run/systemd/system ]; then
    systemctl daemon-reload >/dev/null 2>&1 || :
  fi
}
